<edges>
    <!-- 第一段：大家都得走的进场路 -->
    <edge id="road_in" from="start" to="split" speed="20" numLanes="1"/>
    
    <!-- 主路（收费路段）：又直又快，但是一会儿我们要在这里收拥堵费 -->
    <edge id="road_toll" from="split" to="end" speed="20" numLanes="1"/>
    
    <!-- 绕行小路：从分叉口往上绕，限速比较低（15），相当于没有红绿灯的乡间小道 -->
    <edge id="road_detour1" from="split" to="detour" speed="15" numLanes="1"/>
    <edge id="road_detour2" from="detour" to="end" speed="15" numLanes="1"/>
</edges>