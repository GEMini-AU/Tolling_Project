<routes>
    <!-- 定义一种标准的私家车，加速度和减速度 -->
    <vType id="standard_car" length="5.0" maxSpeed="20.0" accel="2.0" decel="4.5"/>
    
    <!-- 定义车流：在 1 个小时 (3600秒) 内，均匀释放 1000 辆这种车，走 road_1 这条路 -->
    <flow id="car_flow" type="standard_car" begin="0" end="3600" vehsPerHour="1000">
        <route edges="road_1"/>
    </flow>
</routes>