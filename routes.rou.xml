<routes>
    <vType id="car" maxSpeed="20" accel="2" decel="2"/>
    
    <!-- 导航方案A（默认）：走主路，快但可能要交钱 -->
    <route id="route_main" edges="road_in road_toll"/>
    
    <!-- 导航方案B（备用）：走小路，慢但免费 -->
    <route id="route_bypass" edges="road_in road_detour1 road_detour2"/>
    
    <!-- 疯狂发车：每秒钟都以50%的概率随机发一辆车，全部默认先走方案A -->
    <flow id="flow1" type="car" route="route_main" begin="0" end="100" probability="0.5"/>
</routes>