import pandas as pd
import matplotlib.pyplot as plt
import os

# --- 1. 设置专业的中文字体和图表风格 ---
# 设置为好看的网格风格
plt.style.use('ggplot') 
# 解决中文显示乱码问题（Windows常用微软雅黑或黑体）
plt.rcParams['font.sans-serif'] = ['Microsoft YaHei', 'SimHei', 'Arial Unicode MS']
plt.rcParams['axes.unicode_minus'] = False

# --- 2. 读取仿真生成的 CSV 数据 ---
file_name = "weihai_analysis_report.csv"
if not os.path.exists(file_name):
    print(f"找不到文件 {file_name}，请确保 main.py 已经跑完并生成了该文件！")
    exit()

df = pd.read_csv(file_name)

# --- 3. 开始绘制精美图表 ---
print("正在生成数据图表，请稍候...")

# 创建一个 2x2 的大画布 (宽 16, 高 10)
fig, axs = plt.subplots(2, 2, figsize=(16, 10))
fig.suptitle('基于距离的动态道路收费系统 - 仿真数据评估报告', fontsize=20, fontweight='bold', y=0.95)

# ---------------------------------------------------
# 图表 1：CBD 区域内车辆数与动态费率的联动关系 (双Y轴图)
# 对应考核要求：根据实时拥堵水平进行动态定价
# ---------------------------------------------------
ax1 = axs[0, 0]
color1 = 'tab:blue'
ax1.set_xlabel('仿真时间 (秒)', fontsize=12)
ax1.set_ylabel('CBD内车辆数 (辆)', color=color1, fontsize=12)
ax1.plot(df['Time_Step'], df['Vehicles_in_CBD'], color=color1, linewidth=2, label='CBD车辆数')
ax1.tick_params(axis='y', labelcolor=color1)

# 创建共享X轴的第二个Y轴，用来画费率
ax2 = ax1.twinx()  
color2 = 'tab:red'
ax2.set_ylabel('动态拥堵费率 (元)', color=color2, fontsize=12)
# 费率是阶梯跳变的，用 step 画更专业
ax2.step(df['Time_Step'], df['Current_Toll_Fee'], color=color2, linewidth=2, linestyle='--', label='当前费率')
ax2.tick_params(axis='y', labelcolor=color2)
ax1.set_title('图1: 拥堵程度与动态定价响应曲线', fontsize=14)

# ---------------------------------------------------
# 图表 2：城市财政总收入累积曲线
# 对应考核要求：利用数据库事务处理扣费，生成收入数据
# ---------------------------------------------------
ax3 = axs[0, 1]
ax3.plot(df['Time_Step'], df['Total_Revenue'], color='tab:green', linewidth=2.5)
ax3.set_xlabel('仿真时间 (秒)', fontsize=12)
ax3.set_ylabel('累计财政收入 (元)', fontsize=12)
ax3.set_title('图2: 城市收费系统累计总收入增长曲线', fontsize=14)
# 给最后一点标上总金额，让老师一眼看到最终赚了多少钱
final_revenue = df['Total_Revenue'].iloc[-1]
ax3.annotate(f'最终收入: ¥{final_revenue:.2f}', 
             xy=(df['Time_Step'].iloc[-1], final_revenue), 
             xytext=(df['Time_Step'].iloc[-1]*0.7, final_revenue*0.9),
             arrowprops=dict(facecolor='black', shrink=0.05),
             fontsize=12, fontweight='bold')

# ---------------------------------------------------
# 图表 3：全局平均车速变化图
# 对应考核要求：生成平均车速报告，计算收入与延迟比率
# ---------------------------------------------------
ax4 = axs[1, 0]
ax4.plot(df['Time_Step'], df['Average_Speed_mps'], color='tab:orange', linewidth=2)
ax4.set_xlabel('仿真时间 (秒)', fontsize=12)
ax4.set_ylabel('全局平均车速 (m/s)', fontsize=12)
ax4.set_title('图3: 路网全局平均车速波动趋势', fontsize=14)
ax4.axhline(y=df['Average_Speed_mps'].mean(), color='grey', linestyle=':', label='平均车速基线')
ax4.legend()

# ---------------------------------------------------
# 图表 4：绕行车辆累计图 (逃避收费行为分析)
# 对应考核要求：追踪长路径逃避收费行为 (Detour Analysis)
# ---------------------------------------------------
ax5 = axs[1, 1]
ax5.fill_between(df['Time_Step'], df['Detoured_Vehicles'], color='tab:purple', alpha=0.3)
ax5.plot(df['Time_Step'], df['Detoured_Vehicles'], color='tab:purple', linewidth=2)
ax5.set_xlabel('仿真时间 (秒)', fontsize=12)
ax5.set_ylabel('累计绕行车辆数 (辆)', fontsize=12)
ax5.set_title('图4: 价格杠杆触发的避峰绕行车辆统计', fontsize=14)

# --- 4. 调整布局并保存图片 ---
plt.tight_layout(rect=[0, 0.03, 1, 0.93]) # 留出主标题的空间
plt.savefig("weihai_toll_evaluation_charts.png", dpi=300) # 保存为高清图片
print("✅ 图表生成成功！已保存为 weihai_toll_evaluation_charts.png")

# 在电脑上显示出来给你看看
plt.show()